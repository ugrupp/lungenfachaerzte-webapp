# Craft CMS backend URL (no trailing slash)
# Local dev example:  https://api.lungenfachaerzte.ddev.site
# Production example: https://cms.lungenfachaerzte.de
CRAFT_URL=https://api.your-craft-domain.example

# GraphQL bearer token for the public schema
# Generate with: ddev craft graphql/create-token <schema-uuid>
# Or via: Craft CP → GraphQL → Schemas → [schema] → Create Token
GRAPHQL_TOKEN=

# Public base URL of this TanStack Start application
# Used by Craft to generate fully-qualified live-preview URLs
# Must match PRIMARY_SITE_URL in the Craft backend .env
BASE_URL=http://localhost:3000
